{% comment %}
  Render interests without a trailing colon when no keywords/details are present.
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="interest-item">
      {% if entry.icon %}
        <i class="{{ entry.icon }}"></i>
      {% endif %}
      {% if entry.keywords %}
        <strong>{{ entry.name }}:</strong>
        {% for keyword in entry.keywords %}
          {% if forloop.last %}
            {{ keyword }}
          {% else %}
            {{ keyword }},
          {% endif %}
        {% endfor %}
      {% else %}
        <strong>{{ entry.name }}</strong>
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .interest-item {
    padding: 0.5rem 0;
  }
</style>
